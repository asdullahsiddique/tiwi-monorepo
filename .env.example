# Clerk (frontoffice)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Neo4j
# If 7474/7687 are already in use locally, change these and also update NEO4J_URI accordingly.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# S3 compatible (MinIO local)
S3_BUCKET=tiwi
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadminpassword
S3_FORCE_PATH_STYLE=true

# OpenAI
OPENAI_API_KEY=
OPENAI_ENRICHMENT_MODEL=gpt-4o-mini
OPENAI_SUMMARIZATION_MODEL=gpt-4o-mini
OPENAI_SEARCH_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cost estimation (optional; set for accurate cost dashboards/logs)
OPENAI_PRICE_INPUT_PER_1M_USD=0
OPENAI_PRICE_OUTPUT_PER_1M_USD=0

# LangSmith (optional; for LangGraph observability)
# Get your API key at https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=tiwi-enrichment

