# Clerk (frontoffice)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# MongoDB (data + file processing queue)
MONGODB_URI=mongodb://localhost:27017/tiwi

# S3 compatible (MinIO local)
S3_BUCKET=tiwi
S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadminpassword
S3_FORCE_PATH_STYLE=true

# OpenAI
OPENAI_API_KEY=
OPENAI_ENRICHMENT_MODEL=gpt-5-mini
OPENAI_SEARCH_MODEL=gpt-5-mini

# Cost estimation (optional; set for accurate cost dashboards/logs)
OPENAI_PRICE_INPUT_PER_1M_USD=0
OPENAI_PRICE_OUTPUT_PER_1M_USD=0

# Anthropic (daemon document extraction + summarization)
ANTHROPIC_API_KEY=
CLAUDE_AGENT_MODEL=claude-opus-4-7
CLAUDE_AGENT_MAX_TURNS=200
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5
ANTHROPIC_CLAUDE_OPUS_INPUT_USD_PER_1M=15
ANTHROPIC_CLAUDE_OPUS_OUTPUT_USD_PER_1M=75
ANTHROPIC_CLAUDE_SONNET_INPUT_USD_PER_1M=3
ANTHROPIC_CLAUDE_SONNET_OUTPUT_USD_PER_1M=15
ANTHROPIC_CLAUDE_HAIKU_INPUT_USD_PER_1M=1
ANTHROPIC_CLAUDE_HAIKU_OUTPUT_USD_PER_1M=5

# AssemblyAI (optional; for video/audio transcription)
# Get your API key at https://www.assemblyai.com
ASSEMBLYAI_API_KEY=

# LangSmith (optional; for LangGraph observability)
# Get your API key at https://smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=tiwi-enrichment
